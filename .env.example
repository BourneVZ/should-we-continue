# 大模型服务提供商名称，仅用于开发时标识当前连接的是哪一家服务。
# 例：OpenAI、OpenRouter、DeepSeek、Azure OpenAI。
LLM_PROVIDER_NAME=

# 服务端调用大模型接口所需的密钥。
# 只允许放在本地 .env.local 或部署平台的服务端环境变量中，不能放进前端代码。
LLM_API_KEY=

# OpenAI-compatible 接口的基础地址。
# 例：https://api.openai.com/v1
# 末尾通常不要再额外手动加 /chat/completions。
LLM_BASE_URL=

# 便宜一些的分析模型，用于矛盾检查、标签整理等轻量分析步骤。
LLM_MODEL_ANALYSIS=

# 最终报告润色模型，用于生成用户可读的报告叙述层。
LLM_MODEL_REPORT=

# 单次模型请求的超时时间，单位毫秒。
# 例：15000 表示 15 秒。
LLM_TIMEOUT_MS=

# 允许模型返回的最大输出长度上限。
# 当前实现按字符长度做防护，建议先填一个保守值。
# 例：4000
LLM_MAX_OUTPUT_TOKENS=
